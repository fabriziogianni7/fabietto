TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
GROQ_API_KEY=your-groq-api-key-from-console-groq-com
BRAVE_SEARCH_API_KEY=your-brave-search-api-key-from-brave-com-search-api

# Optional gateways (enable at least one above, or add these)
DISCORD_BOT_TOKEN=your-discord-bot-token
HTTP_PORT=5000

# Signal (requires signal-cli-rest-api running, e.g. Docker)
SIGNAL_CLI_URL=http://localhost:8080
SIGNAL_NUMBER=+1234567890

# Context compaction (optional, default 4000)
CONTEXT_COMPACTION_THRESHOLD=4000

# Embeddings via Ollama (optional - enables semantic memory and retrieval)
# Install: https://ollama.ai, then: ollama pull nomic-embed-text
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Skills (optional, default ./skills-data). Directory for user-installed skills (OpenClaw-style SKILL.md).
# Keep this separate from the skills/ package source. SKILLS_DIR=./skills-data

# Wallet (optional). When set, enables wallet tools and x402 buyer for http_request.
EVM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
WALLET_PRIVATE_KEY=0x...
CHAIN_ID=1
WALLET_NATIVE_SPEND_LIMIT=1_000000_000000_000000

# Autonomous mode (optional). When set, LLM uses x402 router instead of Groq; requires wallet.
# GROQ_API_KEY not required. Agent mission: grow capital, sustain own costs.
# Requires: Base (chain 8453) in WALLET_CHAINS or CHAIN_ID=8453; Alchemy for USDC runway checks.
AUTONOMOUS_MODE=0
X402_ROUTER_URL=https://ai.xgate.run/v1
X402_PERMIT_CAP=50
X402_MODEL=openai:gpt-4
X402_MIN_BASE_USDC=10

# Role-specific subagent models (autonomous mode). When spawn_subagents uses role, maps to model.
# Omit to use X402_MODEL for all. Saves cost: parser/research use cheap models.
# X402_MODEL_QUANT=openai:gpt-5
# X402_MODEL_PARSER=openai:gpt-5-nano
# X402_MODEL_RESEARCH=openai:gpt-5-mini
# X402_MODEL_RISK=openai:gpt-5
# X402_MODEL_SUBAGENT=openai:gpt-5-mini

# Opportunity scan cron (autonomous mode only). Periodically invokes agent to scan and act.
# Set OPPORTUNITY_SCAN_INTERVAL_MINUTES>0 to enable; requires TELEGRAM_BOT_TOKEN + TELEGRAM_OWNER_CHAT_ID.
OPPORTUNITY_SCAN_INTERVAL_MINUTES=0
TELEGRAM_OWNER_CHAT_ID=your-telegram-chat-id

# Alchemy Data API (required for autonomous mode). When set, enables portfolio tools: wallet_get_portfolio,
# wallet_get_portfolio_value, wallet_get_activity, wallet_simulate_transaction. Uses Token, Prices, Transfers, Simulation APIs.
# ALCHEMY_API_KEY=your-alchemy-api-key
# ALCHEMY_BASE_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# WALLET_CHAINS for autonomous mode must include Base (chain 8453) for x402 USDC payments:
# WALLET_CHAINS=[{"chain_id":1,"rpc_url":"https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY","explorer":"https://etherscan.io","name":"Ethereum"},{"chain_id":8453,"rpc_url":"https://base-mainnet.g.alchemy.com/v2/YOUR_KEY","explorer":"https://basescan.org","name":"Base"}]
